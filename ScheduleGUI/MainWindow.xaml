<Window x:Class="ScheduleGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScheduleGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#F0F4F8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <ItemsControl x:Name="listaCarduri" Padding="20">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Background="White" CornerRadius="12" Margin="10,10,10,20" Padding="25">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="LightGray" ShadowDepth="5" Opacity="0.4"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding ParentObjective.Title, StringFormat='Obiectiv: {0}', TargetNullValue='Fără obiectiv'}" 
                                       FontSize="14" Foreground="#7F8C8D" FontStyle="Italic" Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="Inceput: " FontWeight="SemiBold" Foreground="#34495E" Width="80"/>
                                    <TextBlock Text="{Binding StartTime, StringFormat=dd/MM/yyyy HH:mm}" Foreground="#2C3E50"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="Final: " FontWeight="SemiBold" Foreground="#34495E" Width="80"/>
                                    <TextBlock Text="{Binding EndTime, StringFormat=dd/MM/yyyy HH:mm}" Foreground="#2C3E50"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <TextBlock Text="Stare: " FontWeight="SemiBold" Foreground="#34495E" Width="80" VerticalAlignment="Center"/>

                                    <Border x:Name="bdStatus" Background="#E74C3C" CornerRadius="5" Padding="10,4">
                                        <TextBlock x:Name="labelStatus" Text="Nefinalizat" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter TargetName="bdStatus" Property="Background" Value="#2ECC71"/>
                                <Setter TargetName="labelStatus" Property="Text" Value="FINALIZAT"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Button Content="+ Adaugă" 
            Click="BtnDeschideAdaugare_Click" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom" 
            Margin="0,0,30,30" 
            Padding="20,12" 
            Background="#6be619" 
            Foreground="White" 
            FontWeight="Bold" 
            BorderThickness="0"
            FontSize="16">

            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
